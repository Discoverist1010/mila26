OPENAI_API_KEY=
AUDIT_AGENT_API_KEY=
MILA26_API_PORT=5174
MILA26_API_HOST=127.0.0.1
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ENABLE_REAL_DEPLOY=false
MILA26_LLM_PROVIDER=mock
MILA26_LLM_MODEL=mila26-mock-model
MILA26_LLM_TIMEOUT_MS=30000
MILA26_LLM_MAX_OUTPUT_TOKENS=2000

# Optional live Sepolia readiness and Evidence Vault checks.
# Normal tests do not use these values. Set LIVE_SEPOLIA=1 only when you intend
# to validate public testnet artefacts and optional RPC receipt lookups.
LIVE_SEPOLIA=0
MILA26_SEPOLIA_RPC_URL=
MILA26_SEPOLIA_ISSUER_ADMIN_ADDRESS=
MILA26_SEPOLIA_PAYMENT_ADDRESS=
MILA26_SEPOLIA_REDEMPTION_WALLET_ADDRESS=
MILA26_SEPOLIA_INVESTOR_ADDRESSES=
MILA26_SEPOLIA_DEPLOYMENT_TX_HASH=
MILA26_SEPOLIA_RECORD_NAV_TX_HASH=
MILA26_SEPOLIA_WALLET_WHITELIST_TX_HASH=
MILA26_SEPOLIA_ALLOCATION_MINT_TX_HASH=
MILA26_LIVE_EVIDENCE_API_BASE_URL=
MILA26_LIVE_EVIDENCE_PROJECT_ID=
# OpenAI mode is backend-only and requires an explicit operator-selected model.
# Example only:
# MILA26_LLM_PROVIDER=openai
# MILA26_LLM_MODEL=gpt-5-mini
# OPENAI_API_KEY=...
