{
  "name": "mila26",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "contracts:build": "hardhat build",
    "contracts:export-artifact": "node scripts/export-mila26-deployment-artifact.mjs",
    "test:contracts": "node --import tsx/esm --test test/Mila26RestrictedFundToken.ts",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lint": "eslint .",
    "test": "vitest run",
    "test:live-openai": "tsx scripts/live-openai-chat.ts",
    "test:live-sepolia": "tsx scripts/live-sepolia-readiness.ts",
    "test:e2e": "playwright test",
    "bundle:size": "node scripts/check-bundle-size.mjs",
    "check": "npm run lint && npm run test && npm run build && npm run bundle:size"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "fastify": "^5.8.5",
    "openai": "^6.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "viem": "^2.51.3",
    "vite": "^7.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.9",
    "@nomicfoundation/hardhat-viem": "^3.0.8",
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "hardhat": "^3.6.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.2.6"
  }
}
